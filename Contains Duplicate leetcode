class Solution {
    public boolean containsDuplicate(int[] nums) {
        HashMap<Integer,Integer> unique = new HashMap<>();
        for(int num : nums){
            if(unique.containsKey(num) && unique.get(num)>= 1 )
            return true;
            unique.put(num,unique.getOrDefault(num,0)+1);
        }
        return false;
        
    }
}
