import java.util.*;

class Solution {
    public int[] asteroidCollision(int[] asteroids) {

        List<Integer> st = new ArrayList<>();

        for (int i = 0; i < asteroids.length; i++) {

            int curr = asteroids[i];
            boolean destroyed = false;

            // Collision happens only when:
            // stack top is moving right (>0) and current is moving left (<0)
            while (!st.isEmpty() && st.get(st.size() - 1) > 0 && curr < 0) {

                int top = st.get(st.size() - 1);

                if (top < Math.abs(curr)) {
                    // top asteroid explodes
                    st.remove(st.size() - 1);
                } 
                else if (top == Math.abs(curr)) {
                    // both explode
                    st.remove(st.size() - 1);
                    destroyed = true;
                    break;
                } 
                else {
                    // current asteroid explodes
                    destroyed = true;
                    break;
                }
            }

            // If current asteroid is not destroyed, add it
            if (!destroyed) {
                st.add(curr);
            }
        }

        // Convert list to array
        int[] result = new int[st.size()];
        for (int i = 0; i < st.size(); i++) {
            result[i] = st.get(i);
        }

        return result;
    }
}
